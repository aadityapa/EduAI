    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@eduai/auth": "workspace:*",
    "@prisma/client": "^6.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
