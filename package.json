{
  "name": "eduai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @eduai/database generate",
    "db:migrate": "pnpm --filter @eduai/database migrate:dev",
    "db:seed": "pnpm --filter @eduai/database seed",
    "db:studio": "pnpm --filter @eduai/database studio",
    "validate:billing": "node backend/testing/scripts/billing-validation.mjs",
    "validate:dr": "node backend/testing/scripts/dr-test-checklist.mjs",
    "load:test": "k6 run backend/testing/load/k6-student-journey.js",
    "mvp:setup": "docker compose -f backend/infrastructure/docker/docker-compose.yml up -d && pnpm db:generate && pnpm db:migrate && pnpm db:seed",
    "dev:backend": "turbo run dev --parallel --filter=@eduai/identity-service --filter=@eduai/learning-service --filter=@eduai/ai-service --filter=@eduai/erp-service --filter=@eduai/billing-service",
    "dev:frontend": "turbo run dev --parallel --filter=@eduai/web --filter=@eduai/admin",
    "dev:mobile": "pnpm --filter @eduai/mobile dev",
    "clean:next": "node -e \"const fs=require('fs');['frontend/web','frontend/admin'].forEach(p=>{try{fs.rmSync(p+'/.next',{recursive:true,force:true})}catch{}});console.log('Cleaned .next caches')\"",
    "mvp:dev": "pnpm clean:next && turbo run dev --parallel --filter=@eduai/identity-service --filter=@eduai/learning-service --filter=@eduai/ai-service --filter=@eduai/erp-service --filter=@eduai/billing-service --filter=@eduai/web --filter=@eduai/admin",
    "dev:lan": "powershell -ExecutionPolicy Bypass -File backend/testing/scripts/dev-lan.ps1",
    "stitch:sync": "node backend/testing/scripts/stitch-sync.mjs all",
    "stitch:generate": "node backend/testing/scripts/stitch-sync.mjs generate",
    "stitch:generate:next": "node backend/testing/scripts/stitch-sync.mjs generate:next",
    "stitch:fetch": "node backend/testing/scripts/stitch-sync.mjs fetch",
    "stitch:backfill": "node backend/testing/scripts/stitch-sync.mjs backfill"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~18.3.12"
    }
  }
}
