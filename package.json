{
  "name": "eduai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @eduai/database generate",
    "db:migrate": "pnpm --filter @eduai/database migrate:dev",
    "db:seed": "pnpm --filter @eduai/database seed",
    "db:studio": "pnpm --filter @eduai/database studio",
    "validate:billing": "node scripts/billing-validation.mjs",
    "validate:dr": "node scripts/dr-test-checklist.mjs",
    "load:test": "k6 run tests/load/k6-student-journey.js",
    "mvp:setup": "docker compose -f infrastructure/docker/docker-compose.yml up -d && pnpm db:generate && pnpm db:migrate && pnpm db:seed",
    "mvp:dev": "turbo run dev --parallel --filter=@eduai/identity-service --filter=@eduai/learning-service --filter=@eduai/ai-service --filter=@eduai/erp-service --filter=@eduai/billing-service --filter=@eduai/web --filter=@eduai/admin"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~18.3.12"
    }
  }
}
