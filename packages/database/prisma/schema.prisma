enum AcademicClassStatus {
  active
  archived
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum LeaveStatus {
  pending
  approved
  rejected
  cancelled
}

enum FeeInvoiceStatus {
  draft
  issued
  partial
  paid
  overdue
  cancelled
}

enum ExamStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum AssignmentStatus {
  draft
  published
  closed
}

enum NotificationChannel {
  in_app
  email
  sms
  push
}

enum DocumentType {
  certificate
  report
  policy
  transcript
  other
}

enum BillingProvider {
  stripe
  razorpay
  manual
}

enum SubscriptionPlanType {
  student
  coaching
  school
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  expired
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum LeadStatus {
  new
  contacted
  qualified
  converted
  lost
}

enum CampaignStatus {
  draft
  active
  paused
  completed
}

model AcademicClass {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  schoolId     String              @map("school_id") @db.Uuid
  name         String              @db.VarChar(100)
  section      String              @db.VarChar(10)
  classLevel   Int                 @map("class_level") @db.SmallInt
  academicYear String              @map("academic_year") @db.VarChar(20)
  teacherId    String?             @map("teacher_id") @db.Uuid
  room         String?             @db.VarChar(50)
  status       AcademicClassStatus @default(active)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  school       School            @relation(fields: [schoolId], references: [id])
  enrollments  ClassEnrollment[]
  attendance   AttendanceRecord[]
  exams        Exam[]
  timetable    TimetableSlot[]
  assignments  Assignment[]

  @@unique([tenantId, schoolId, name, section, academicYear])
  @@index([tenantId, schoolId], map: "idx_academic_classes_tenant")
  @@map("academic_classes")
}

