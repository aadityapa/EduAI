  title        String       @db.VarChar(255)
  type         DocumentType @default(other)
  url          String       @db.VarChar(500)
  uploadedById String       @map("uploaded_by_id") @db.Uuid
  metadata     Json         @default("{}")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([tenantId, type], map: "idx_documents_tenant")
  @@map("documents")
}

// ============================================================
// Sprint 4: Billing & CRM
// ============================================================

model SubscriptionPlan {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String               @unique @db.VarChar(50)
  name         String               @db.VarChar(100)
  type         SubscriptionPlanType
  priceMonthly Decimal              @map("price_monthly") @db.Decimal(12, 2)
  priceYearly  Decimal              @map("price_yearly") @db.Decimal(12, 2)
  currency     String               @default("INR") @db.VarChar(3)
  maxStudents  Int                  @default(100) @map("max_students")
  aiTokenBudget Int                 @default(500000) @map("ai_token_budget")
  features     Json                 @default("[]")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz

  subscriptions TenantSubscription[]

  @@map("subscription_plans")
}

model TenantSubscription {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String             @map("tenant_id") @db.Uuid
  planId               String             @map("plan_id") @db.Uuid
  status               SubscriptionStatus @default(trialing)
  provider             BillingProvider    @default(manual)
  externalSubscriptionId String?          @map("external_subscription_id") @db.VarChar(255)
  currentPeriodStart   DateTime           @map("current_period_start") @db.Timestamptz
  currentPeriodEnd     DateTime           @map("current_period_end") @db.Timestamptz
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices BillingInvoice[]

  @@index([tenantId], map: "idx_tenant_subscriptions_tenant")
  @@map("tenant_subscriptions")
}

model BillingInvoice {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  subscriptionId String?         @map("subscription_id") @db.Uuid
  invoiceNumber  String          @map("invoice_number") @db.VarChar(50)
  amount         Decimal         @db.Decimal(12, 2)
  gstAmount      Decimal         @default(0) @map("gst_amount") @db.Decimal(12, 2)
  currency       String          @default("INR") @db.VarChar(3)
  status         FeeInvoiceStatus @default(issued)
  provider       BillingProvider @default(manual)
  externalId     String?         @map("external_id") @db.VarChar(255)
  dueDate        DateTime        @map("due_date") @db.Date
  paidAt         DateTime?       @map("paid_at") @db.Timestamptz
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  subscription TenantSubscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@map("billing_invoices")
}

model Coupon {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String?   @map("tenant_id") @db.Uuid
  code          String    @db.VarChar(50)
  discountPct   Decimal   @map("discount_pct") @db.Decimal(5, 2)
  maxUses       Int       @default(100) @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  validFrom     DateTime  @map("valid_from") @db.Timestamptz
  validUntil    DateTime  @map("valid_until") @db.Timestamptz
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([code])
  @@map("coupons")
}

model Lead {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?    @map("tenant_id") @db.Uuid
  name      String     @db.VarChar(255)
  email     String     @db.VarChar(255)
  phone     String?    @db.VarChar(20)
  organization String? @db.VarChar(255)
  source    String?    @db.VarChar(100)
  status    LeadStatus @default(new)
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([status], map: "idx_leads_status")
  @@map("leads")
}

model SupportTicket {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  createdById  String       @map("created_by_id") @db.Uuid
  assignedToId String?      @map("assigned_to_id") @db.Uuid
  subject      String       @db.VarChar(255)
  description  String
  status       TicketStatus @default(open)
  priority     String       @default("medium") @db.VarChar(20)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  createdBy  User   @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo User?  @relation("TicketAssignee", fields: [assignedToId], references: [id])

  @@index([tenantId, status], map: "idx_support_tickets_status")
  @@map("support_tickets")
}

model MarketingCampaign {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?        @map("tenant_id") @db.Uuid
  name      String         @db.VarChar(255)
  channel   String         @db.VarChar(50)
  status    CampaignStatus @default(draft)
  budget    Decimal?       @db.Decimal(12, 2)
  metadata  Json           @default("{}")
  startsAt  DateTime?      @map("starts_at") @db.Timestamptz
  endsAt    DateTime?      @map("ends_at") @db.Timestamptz
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@map("marketing_campaigns")
}

model ActivityLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String   @db.VarChar(100)
  resourceType String?  @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.Uuid
  metadata     Json     @default("{}")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)], map: "idx_activity_logs_tenant")
  @@map("activity_logs")
}

model TenantBranding {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String  @unique @map("tenant_id") @db.Uuid
  logoUrl              String? @map("logo_url") @db.VarChar(500)
  primaryColor         String  @default("#6366f1") @map("primary_color") @db.VarChar(7)
  secondaryColor       String  @default("#8b5cf6") @map("secondary_color") @db.VarChar(7)
  accentColor          String  @default("#f59e0b") @map("accent_color") @db.VarChar(7)
  fontFamily           String  @default("Inter") @map("font_family") @db.VarChar(100)
  customCss            String? @map("custom_css")
  faviconUrl           String? @map("favicon_url") @db.VarChar(500)
  emailFromName        String? @map("email_from_name") @db.VarChar(100)
  emailHeaderHtml      String? @map("email_header_html")
  emailFooterHtml      String? @map("email_footer_html")
  mobileAppName        String? @map("mobile_app_name") @db.VarChar(100)
  customDomainVerified Boolean @default(false) @map("custom_domain_verified")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_branding")
}
